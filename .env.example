APP_NAME="Judger AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=judger_ai
DB_USERNAME=judger
DB_PASSWORD=password

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

AI_PROVIDER=mock
AI_EMBEDDING_PROVIDER=mock
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
AI_EMBEDDING_BATCH_SIZE=12
AI_DOCUMENT_EXTRACTION_COMMAND_TIMEOUT=90
AI_EMBEDDING_REQUEST_TIMEOUT=90
AI_KNOWLEDGE_STEP_CHUNK_COUNT=4
AI_KNOWLEDGE_PROCESSING_STALE_MINUTES=30
AI_VECTOR_STORE=auto
AI_DOCUMENT_SIMILARITY_THRESHOLD=0.70
AI_MAX_CASE_DOCUMENT_CHUNKS=8
AI_MAX_KNOWLEDGE_CHUNKS=8
AI_MAX_CONTEXT_CHUNKS=14
AI_RECENT_MESSAGES_LIMIT=12
AI_MAX_CASE_MEMORIES=20
AI_WEB_SEARCH_ENABLED=false
AI_WEB_SEARCH_PROVIDER=brave

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_KNOWLEDGE_COLLECTION=legal_knowledge_chunks
QDRANT_CASE_COLLECTION=legal_case_chunks

BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DOMAIN=localhost

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@judgerai.app"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
